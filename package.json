{
  "name": "dox",
  "version": "1.0.0",
  "description": "Dox - all your shared docs in one place",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@azure/msal-node": "^5.0.5",
    "@fluentui/react-components": "^9.56.5",
    "@fluentui/react-icons": "^2.0.270",
    "date-fns": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^7.2.0"
  }
}
